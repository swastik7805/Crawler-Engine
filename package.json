{
  "name": "web3-crawler",
  "version": "1.0.0",
  "description": "Domain-specific Web3 crawler for The Chronicle search engine",
  "keywords": [
    "crawler",
    "web3",
    "postGres",
    "inverted-b-tree",
    "ai"
  ],
  "license": "ISC",
  "author": "Swastik Sharma",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts all",
    "dev:orchestrator": "tsx watch src/index.ts orchestrator",
    "dev:fetcher": "tsx watch src/index.ts fetcher",
    "dev:processor": "tsx watch src/index.ts processor",
    "build": "tsc --noEmit",
    "start": "tsx src/index.ts all",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed-extensions": "tsx src/db/apply-manual.ts",
    "test": "cross-env NODE_OPTIONS='--experimental-vm-modules' jest --verbose"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "bullmq": "^5.74.1",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.32.0",
    "ioredis": "^5.10.1",
    "p-queue": "^8.0.1",
    "p-retry": "^6.2.0",
    "pg": "^8.12.0",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.23.0",
    "jest": "^30.3.0",
    "nock": "^14.0.12",
    "ts-jest": "^29.4.9",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
